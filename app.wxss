page {
  min-height: 100%;
  background: #f5f1e8;
  color: #1f2933;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
}

button {
  border-radius: 0;
}

.primary-button {
  background: #0f766e;
  color: #fff;
  border-radius: 12rpx;
  font-weight: 600;
}

.ghost-button {
  background: rgba(255, 255, 255, 0.9);
  color: #14342f;
  border: 1rpx solid rgba(20, 52, 47, 0.18);
  border-radius: 12rpx;
}

.card {
  background: rgba(255, 255, 255, 0.94);
  border: 1rpx solid rgba(31, 41, 51, 0.08);
  border-radius: 14rpx;
  box-shadow: 0 14rpx 36rpx rgba(31, 41, 51, 0.08);
}
