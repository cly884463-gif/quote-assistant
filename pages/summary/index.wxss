.summary-page {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
  background: #f5f1e8;
}

.settings {
  padding: 22rpx;
}

.field {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 16rpx;
  color: #24352f;
  font-size: 26rpx;
}

.field:last-child {
  margin-bottom: 0;
}

.export-btn {
  margin-top: 20rpx;
  height: 68rpx;
  line-height: 68rpx;
  background: #0f766e;
  color: #fff;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 700;
}

.select {
  flex: 1;
  height: 60rpx;
  padding: 0 16rpx;
  box-sizing: border-box;
  background: #f8faf9;
  border: 1rpx solid rgba(31, 41, 51, 0.1);
  border-radius: 8rpx;
  text-align: right;
}

.select view {
  height: 60rpx;
  line-height: 60rpx;
}

.sheet-wrap {
  margin-top: 22rpx;
  width: 100%;
}

.sheet {
  min-width: 1060rpx;
  background: #fff;
  border-left: 1rpx solid #1f2933;
  font-size: 22rpx;
}

.top-row {
  display: grid;
  grid-template-columns: 110rpx 130rpx 260rpx 120rpx 100rpx 150rpx 70rpx 80rpx 130rpx 140rpx;
  background: #fff200;
  color: #111827;
  font-weight: 700;
}

.top-row text {
  padding: 8rpx 12rpx;
  box-sizing: border-box;
  background: #fff200;
  border-top: 1rpx solid #1f2933;
  border-right: 1rpx solid #1f2933;
  border-bottom: 1rpx solid #1f2933;
}

.top-logistics {
  grid-column: 1 / span 5;
}

.top-delivery {
  grid-column: 6 / span 5;
  text-align: right;
}

.row {
  display: grid;
  grid-template-columns: 110rpx 130rpx 260rpx 120rpx 100rpx 150rpx 70rpx 80rpx 130rpx 140rpx;
}

.row text {
  min-height: 54rpx;
  padding: 8rpx 10rpx;
  box-sizing: border-box;
  border-right: 1rpx solid #1f2933;
  border-bottom: 1rpx solid #1f2933;
  text-align: center;
  line-height: 1.3;
}

.header text {
  background: #f3f4f6;
  font-weight: 700;
}

.green {
  background: #10b981;
  color: #052e24;
  font-weight: 700;
}

.total-row {
  display: grid;
  grid-template-columns: 110rpx 130rpx 260rpx 120rpx 100rpx 150rpx 70rpx 80rpx 130rpx 140rpx;
}

.total-row text {
  min-height: 42rpx;
  padding: 8rpx 10rpx;
  box-sizing: border-box;
  border-right: 1rpx solid #1f2933;
  border-bottom: 1rpx solid #1f2933;
  line-height: 1.25;
}

.total-label {
  grid-column: 1 / span 9;
  text-align: right;
}

.total-value {
  grid-column: 10 / span 1;
  text-align: center;
}

.strong {
  font-weight: 800;
}

.notes {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  margin-top: 22rpx;
  padding: 22rpx;
  color: #374151;
  font-size: 24rpx;
  line-height: 1.45;
}

.notes-title {
  color: #17231f;
  font-size: 28rpx;
  font-weight: 700;
}

.export-canvas {
  position: fixed;
  left: -2000px;
  top: -2000px;
  z-index: -1;
}
