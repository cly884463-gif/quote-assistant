.home {
  position: relative;
  min-height: 100vh;
  padding: 36rpx 28rpx 44rpx;
  box-sizing: border-box;
  overflow: hidden;
}

.hero-bg,
.shade {
  position: fixed;
  inset: 0;
  width: 100%;
  height: 100%;
}

.hero-bg {
  z-index: 0;
}

.shade {
  z-index: 1;
  background: linear-gradient(180deg, rgba(8, 15, 12, 0.58), rgba(8, 15, 12, 0.24) 42%, rgba(245, 241, 232, 0.96) 72%);
}

.topbar,
.hero-copy,
.product-panel {
  position: relative;
  z-index: 2;
}

.topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
}

.eyebrow {
  color: rgba(255, 255, 255, 0.76);
  font-size: 22rpx;
}

.title {
  margin-top: 6rpx;
  color: #fff;
  font-size: 38rpx;
  font-weight: 700;
}

.quote-actions {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  width: 320rpx;
}

.create-btn {
  width: 100%;
  height: 68rpx;
  line-height: 68rpx;
  padding: 0;
  background: #f6d36b;
  color: #17231f;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 700;
}

.hero-copy {
  margin-top: 128rpx;
  color: #fff;
}

.headline {
  width: 520rpx;
  font-size: 58rpx;
  line-height: 1.12;
  font-weight: 800;
}

.subline {
  margin-top: 18rpx;
  color: rgba(255, 255, 255, 0.86);
  font-size: 28rpx;
}

.product-panel {
  margin-top: 220rpx;
}

.panel-title {
  margin-bottom: 20rpx;
  color: #1c2c27;
  font-size: 34rpx;
  font-weight: 700;
}

.category-list,
.product-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.category-section {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.category-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 22rpx 24rpx;
  background: rgba(255, 255, 255, 0.92);
  border: 1rpx solid rgba(15, 118, 110, 0.16);
  border-radius: 14rpx;
  box-shadow: 0 12rpx 28rpx rgba(31, 41, 51, 0.07);
}

.category-name {
  display: block;
  color: #14342f;
  font-size: 32rpx;
  font-weight: 800;
}

.category-count {
  display: block;
  margin-top: 6rpx;
  color: #6b7a75;
  font-size: 24rpx;
}

.category-arrow {
  color: #0f766e;
  font-size: 26rpx;
  font-weight: 700;
}

.product-card {
  padding: 24rpx;
}

.card-head {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
}

.model {
  color: #0f766e;
  font-size: 26rpx;
  font-weight: 700;
}

.category {
  color: #6b5b2a;
  font-size: 24rpx;
}

.name {
  margin-top: 12rpx;
  color: #16231f;
  font-size: 32rpx;
  font-weight: 700;
}

.spec-table {
  margin-top: 18rpx;
  overflow: hidden;
  border: 1rpx solid rgba(15, 118, 110, 0.12);
  border-radius: 10rpx;
  background: rgba(248, 250, 249, 0.78);
}

.spec-head,
.spec-row {
  display: grid;
  grid-template-columns: 1.2fr 1.25fr 1fr 1fr;
  align-items: center;
  min-height: 48rpx;
  padding: 0 14rpx;
  column-gap: 10rpx;
  font-size: 24rpx;
}

.spec-head {
  color: #64746e;
  background: rgba(15, 118, 110, 0.08);
  font-weight: 700;
}

.spec-row {
  color: #24352f;
  border-top: 1rpx solid rgba(15, 118, 110, 0.1);
}

.spec-row text:nth-child(3) {
  color: #b45309;
  font-weight: 700;
}

.spec-row text:nth-child(4) {
  color: #0f766e;
  font-weight: 700;
}
